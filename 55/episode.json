    {
      "conceptSlug": "should-have",
      "conceptName": "Should have (debería haber)",
      "category": "Verb construction",
      "role": "introduced",
      "summary": "Should = debería (conditional of deber, to owe/must). Should have = debería haber + participle.",
      "rule": "Debería + haber + past participle = should have done",
      "examples": [
        {"spanish": "Debería haber cancelado", "english": "I should have cancelled"},
        {"spanish": "Lo debería haber cancelado", "english": "I should have cancelled it"},
        {"spanish": "Debería haberlo cancelado", "english": "I should have cancelled it"}
      ],
      "notes": "Lo can go before debería or attached to haber (haberlo)."
    },
    {
      "conceptSlug": "could-have",
      "conceptName": "Could have (podría haber)",
      "category": "Verb construction",
      "role": "introduced",
      "summary": "Could have = podría haber + participle. Uses the conditional of poder.",
      "rule": "Podría + haber + past participle = could have done",
      "examples": [
        {"spanish": "Podría haber ido", "english": "I could have gone"},
        {"spanish": "Podríamos haber ido", "english": "We could have gone"}
      ],
      "notes": null
    },
    {
      "conceptSlug": "irregular-past-participles",
      "conceptName": "Irregular past participles",
      "category": "Verb conjugation",
      "role": "introduced",
      "summary": "Several common verbs have irregular past participles: romper->roto, morir->muerto, abrir->abierto, decir->dicho, hacer->hecho. These irregular forms are used both after haber and as adjectives.",
      "rule": "Romper->roto, morir->muerto, abrir->abierto, decir->dicho, hacer->hecho",
      "examples": [
        {"spanish": "Lo he roto", "english": "I have broken it"},
        {"spanish": "Se ha roto", "english": "It has broken"},
        {"spanish": "Está roto", "english": "It is broken"},
        {"spanish": "Está rota", "english": "It is broken (feminine)"},
        {"spanish": "Ha muerto", "english": "He has died"},
        {"spanish": "Está muerto", "english": "He is dead"},
        {"spanish": "Estoy muerta", "english": "I'm dead (used for exhausted)"},
        {"spanish": "Me muero", "english": "I'm dying (exclamation)"},
        {"spanish": "Lo he abierto", "english": "I have opened it"},
        {"spanish": "Está abierto", "english": "It is open"},
        {"spanish": "Están abiertos", "english": "They are open"},
        {"spanish": "Lo he dicho", "english": "I have said it"},
        {"spanish": "Le he dicho", "english": "I have told him"},
        {"spanish": "Lo he hecho", "english": "I have done it"},
        {"spanish": "Está hecho", "english": "It is done"},
        {"spanish": "Debería haberlo hecho", "english": "I should have done it"},
        {"spanish": "Deberías haberlo hecho", "english": "You should have done it"}
      ],
      "notes": "Dicho and hecho both have the /ch/ sound. Un dicho = a saying (noun). Un hecho = a fact (noun). Hecho en España = made in Spain. Muerto always goes with estar, never ser."
    },
    {
      "conceptSlug": "f-to-h-sound-change",
      "conceptName": "F to silent H sound change",
      "category": "Vocabulary strategy",
      "role": "introduced",
      "summary": "A phonetic change in Spanish history turned many f's into silent h's. This creates connections: hecho/fact, hablar/fable, huir/fugitive, hermano/fraternal, hembra/feminine, hierro/ferrocarril, hondo/profundo, humo/fumar.",
      "rule": "Latin f often became silent h in Spanish. Look for f/h pairs between English and Spanish.",
      "examples": [
        {"spanish": "hecho - fact", "english": "hacer/hecho relates to fact/faire"},
        {"spanish": "hablar - fable", "english": "hablar relates to fable"},
        {"spanish": "huir - fugitive", "english": "huir (to flee) relates to fugitive"},
        {"spanish": "hermano - fraternal", "english": "hermano (brother) relates to fraternal"},
        {"spanish": "hierro - ferrocarril", "english": "iron - railway (within Spanish)"}
      ],
      "notes": "Also w/g pairs: war/guerra, William/Guillermo. These letter-pair connections aid vocabulary memory."
    }
  ],
